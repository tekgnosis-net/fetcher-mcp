{
  "name": "fetcher-mcp",
  "version": "0.3.5",
  "description": "MCP server for fetching web content using Playwright browser",
  "private": false,
  "type": "module",
  "bin": {
    "fetcher-mcp": "build/index.js"
  },
  "files": [
    "build",
    "icon.svg"
  ],
  "scripts": {
    "build": "rm -rf build && tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "inspector": "npm run build && npx @modelcontextprotocol/inspector build/index.js --debug",
    "install-browser": "npx playwright install chromium",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "express": "^4.22.1",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3"
  },
  "main": "index.js",
  "keywords": [
    "mcp",
    "playwright",
    "web-scraping",
    "readability",
    "content-extraction"
  ],
  "author": "",
  "license": "ISC"
}
